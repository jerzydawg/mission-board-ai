# MrDelegate Platform — Environment Variables Template
# -------------------------------------------------------
# DO NOT put real keys here. This file is committed to git.
# Real keys live in TWO places:
#   1. /etc/systemd/system/mrdelegate-platform.service.d/env.conf  (production)
#   2. /root/mrdelegate-secrets/env-backup.conf  (encrypted backup)
#
# To restore: cp /root/mrdelegate-secrets/env-backup.conf /etc/systemd/system/mrdelegate-platform.service.d/env.conf
#             systemctl daemon-reload && systemctl restart mrdelegate-platform

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Auth ──────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
JWT_SECRET=...

# ── Notifications ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
FOUNDER_TELEGRAM_ID=262207319
RESEND_API_KEY=re_...

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://mrdelegate.ai
