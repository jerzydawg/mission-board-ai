</div>

<div class="main">
  <div class="page-header">
    <div class="page-title-group">
      <h1>Fleet Command</h1>
      <p class="page-subtitle">Real-time autonomous agent monitoring</p>
    </div>
    <div class="header-right">
      <div class="ds-live-chip">
        <span class="ds-live-dot"></span>
