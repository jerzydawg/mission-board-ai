<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fleet Command — MrDelegate Operations</title>
<link rel="icon" type="image/x-icon" href="https://mrdelegate.ai/favicon.ico">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/design-system.css">
<style>
  /* ── Page-level vars ── */
  :root {
    --sidebar-w: 220px;
  }

  body {
    background: var(--bg);
    color: var(--text-2);
    font-family: var(--font-ui);
    font-size: 14px;
    line-height: 1.5;
    min-height: 100vh;
    display: flex;
    -webkit-font-smoothing: antialiased;
  }

  /* ─── SIDEBAR ─── */
  .sidebar {
    width: var(--sidebar-w);
    min-height: 100vh;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    z-index: 100;
    box-shadow: 1px 0 0 0 var(--border);
  }

  .sidebar-header {
    padding: 20px 16px;
    border-bottom: 1px solid var(--border);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 2px;
  }

  .logo-mark svg { width: 28px; height: 28px; }

  .logo-name {
    font-size: 14px;
    font-weight: 800;
    color: var(--text-1);
    letter-spacing: -0.01em;
  }
  .logo-name span { color: var(--brand); }

  .logo-subtitle {
    font-size: 9px;
    color: var(--text-4);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding-left: 36px;
  }

  .nav-section { padding: 16px 8px 8px; }

  .nav-label {
    font-size: 9px;
    font-weight: 700;
    color: var(--text-4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0 8px 6px;
    font-family: var(--font-mono);
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 8px;
    margin-bottom: 2px;
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-3);
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease-out),
                color var(--dur-fast) var(--ease-out);
    position: relative;
  }

  .nav-item:hover {
    background: var(--brand-dim);
    color: var(--text-1);
    text-decoration: none;
  }

  .nav-item.active {
    background: var(--brand-dim);
    color: var(--brand);
    font-weight: 600;
    border-left: 2px solid var(--brand);
    padding-left: 6px;
  }

  .nav-icon { font-size: 14px; width: 18px; text-align: center; flex-shrink: 0; }

  .sidebar-footer {
    margin-top: auto;
    padding: 14px 12px;
    border-top: 1px solid var(--border);
  }

  .sidebar-user-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px;
    border-radius: var(--radius-md);
    margin-bottom: 10px;
  }

  .sidebar-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--brand-dim);
    border: 1px solid var(--brand-mid);
    display: grid;
    place-items: center;
    font-size: 12px;
    font-weight: 700;
    color: var(--brand);
    flex-shrink: 0;
  }

  .sidebar-user-info { min-width: 0; flex: 1; }
  .sidebar-user-name { font-size: 12px; font-weight: 600; color: var(--text-1); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sidebar-user-role { font-size: 10px; color: var(--text-4); font-family: var(--font-mono); }

  .sidebar-signout {
    background: none; border: none; color: var(--text-3);
    font-size: 10px; cursor: pointer; padding: 0;
    font-family: var(--font-mono); transition: color var(--dur-fast);
    display: block; margin-top: 4px;
  }
  .sidebar-signout:hover { color: var(--danger); }

  .system-status {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--success-dim);
    border: 1px solid oklch(55% 0.15 145 / 0.18);
    padding: 8px 12px;
    border-radius: var(--radius-md);
    font-size: 11px;
    color: var(--success);
    font-weight: 600;
    font-family: var(--font-mono);
  }

  /* ─── MAIN ─── */
  .main {
    margin-left: var(--sidebar-w);
    flex: 1;
    padding: 28px 32px;
    max-width: calc(100vw - var(--sidebar-w));
    min-height: 100vh;
  }

  /* ─── PAGE HEADER ─── */
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .page-title-group h1 {
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text-1);
    margin-bottom: 4px;
  }

  .page-subtitle {
    font-size: 12px;
    color: var(--text-4);
    font-family: var(--font-mono);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .timestamp-badge {
    font-size: 11px;
    color: var(--text-4);
    font-family: var(--font-mono);
    background: var(--bg-subtle, oklch(97% 0.006 60));
    border: 1px solid var(--border);
    padding: 6px 12px;
    border-radius: var(--radius-md);
  }

  /* ─── METRICS GRID ─── */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .metric-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur-base) var(--ease-out),
                box-shadow var(--dur-base) var(--ease-out),
                border-color var(--dur-base) var(--ease-out);
  }

  .metric-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--border-2);
  }

  .metric-card.accent-brand  { border-top: 2px solid var(--brand); }
  .metric-card.accent-green  { border-top: 2px solid var(--success); }
  .metric-card.accent-warn   { border-top: 2px solid var(--warn); }
  .metric-card.accent-info   { border-top: 2px solid var(--info); }

  .metric-label {
    font-size: 10px;
    color: var(--text-4);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .metric-value {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 8px;
    font-variant-numeric: tabular-nums;
  }

  .metric-value.brand  { color: var(--brand); }
  .metric-value.green  { color: var(--success); }
  .metric-value.warn   { color: var(--warn); }
  .metric-value.info   { color: var(--info); }

  .metric-change {
    font-size: 11px;
    font-family: var(--font-mono);
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--text-4);
  }
  .metric-change.up { color: var(--success); }
  .metric-change.down { color: var(--danger); }

  /* ─── CONTENT GRID ─── */
  .content-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .panel-header {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-subtle, oklch(98.5% 0.004 60));
  }

  .panel-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-1);
    letter-spacing: -0.01em;
  }

  .panel-badge {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--text-4);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
  }

  .panel-body { padding: 20px; }

  /* ─── FLEET AGENTS ─── */
  .fleet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 14px;
  }

  .agent-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 16px;
    transition: border-color var(--dur-base) var(--ease-out),
                box-shadow var(--dur-base) var(--ease-out);
  }

  .agent-card:hover {
    border-color: var(--brand);
    box-shadow: 0 0 0 3px oklch(55% 0.18 250 / 0.06), var(--shadow-sm);
  }

  .agent-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .agent-avatar {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--brand-dim);
    border: 1.5px solid oklch(55% 0.18 250 / 0.2);
    display: grid;
    place-items: center;
    font-size: 20px;
    flex-shrink: 0;
  }
  .agent-avatar.error { background: var(--danger-dim); border-color: oklch(55% 0.18 25 / 0.2); }
  .agent-avatar.idle  { background: var(--info-dim);   border-color: oklch(60% 0.15 230 / 0.2); }

  .agent-info h3 { font-size: 13px; font-weight: 700; color: var(--text-1); margin-bottom: 1px; }
  .agent-role { font-size: 10px; color: var(--text-4); font-family: var(--font-mono); }

  .agent-status-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-family: var(--font-mono);
    padding: 3px 8px;
    border-radius: var(--radius-full);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }
  .agent-status-chip.live  { background: var(--success-dim); color: var(--success); border: 1px solid oklch(55% 0.15 145 / 0.2); }
  .agent-status-chip.error { background: var(--danger-dim);  color: var(--danger);  border: 1px solid oklch(55% 0.18 25 / 0.2); }
  .agent-status-chip.idle  { background: var(--info-dim);    color: var(--info);    border: 1px solid oklch(60% 0.15 230 / 0.2); }

  .agent-message {
    font-size: 11px;
    color: var(--text-3);
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .agent-stats {
    display: flex;
    gap: 10px;
    border-top: 1px solid var(--border);
    padding-top: 10px;
  }

  .stat { flex: 1; text-align: center; }
  .stat-value { font-weight: 700; color: var(--text-1); font-size: 15px; font-variant-numeric: tabular-nums; }
  .stat-label { color: var(--text-4); margin-top: 1px; font-size: 9px; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.06em; }

  /* ─── ACTIVITY FEED ─── */
  .activity-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .activity-item:last-child { border-bottom: none; }

  .activity-icon {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-md);
    display: grid;
    place-items: center;
    font-size: 14px;
    flex-shrink: 0;
  }
  .activity-icon.success { background: var(--success-dim); }
  .activity-icon.info    { background: var(--brand-dim); }
  .activity-icon.warning { background: var(--warn-dim); }

  .activity-content { flex: 1; min-width: 0; }
  .activity-title { font-size: 12px; font-weight: 600; color: var(--text-1); margin-bottom: 2px; }
  .activity-desc  { font-size: 11px; color: var(--text-3); line-height: 1.4; }
  .activity-time  { font-size: 10px; color: var(--text-4); font-family: var(--font-mono); white-space: nowrap; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1200px) {
    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    .content-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .sidebar { transform: translateX(-100%); }
    .main { margin-left: 0; padding: 20px 16px; max-width: 100vw; }
    .metrics-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .metrics-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

