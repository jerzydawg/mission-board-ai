<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MrDelegate — Operations Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --void: #050508;
    --surface: #0d0d12;
    --panel: #111118;
    --border: #1e1e2a;
    --border-bright: #2a2a3a;
    --signal: #7c6af7;
    --signal-dim: rgba(124,106,247,0.12);
    --signal-glow: rgba(124,106,247,0.4);
    --emerald: #10e87e;
    --emerald-dim: rgba(16,232,126,0.1);
    --amber: #f5a623;
    --amber-dim: rgba(245,166,35,0.1);
    --red: #ff4d6d;
    --red-dim: rgba(255,77,109,0.1);
    --blue: #3b82f6;
    --blue-dim: rgba(59,130,246,0.1);
    --white: #f0eeff;
    --muted: #6b6b8a;
    --dim: #3a3a5c;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--void); color:var(--white); font-family:'Syne',sans-serif; display:flex; min-height:100vh; }

  /* ─── SIDEBAR ─── */
  .sidebar {
    width: 220px; min-height: 100vh;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column;
    padding: 24px 0;
    position: fixed; top:0; left:0; bottom:0;
  }
  .sidebar-logo {
    display: flex; align-items: center; gap: 10px;
    padding: 0 20px 24px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;
  }
  .logo-mark {
    width:32px; height:32px; background:var(--signal);
    border-radius:8px; display:grid; place-items:center; font-size:16px;
  }
  .logo-text { font-size:15px; font-weight:800; letter-spacing:-0.3px; }
  .logo-sub { font-size:10px; color:var(--muted); font-family:'JetBrains Mono',monospace; margin-top:1px; }
  .nav-section { padding: 0 12px; margin-bottom: 8px; }
  .nav-label { font-size:10px; color:var(--muted); font-family:'JetBrains Mono',monospace; letter-spacing:1px; padding: 8px 8px 4px; text-transform:uppercase; }
  .nav-item {
    display:flex; align-items:center; gap:10px;
    padding:9px 10px; border-radius:8px;
    font-size:13px; font-weight:600; color:var(--muted);
    cursor:pointer; transition:all 0.15s;
    text-decoration:none;
  }
  .nav-item:hover { background:var(--panel); color:var(--white); }
  .nav-item.active { background:var(--signal-dim); color:var(--signal); }
  .nav-icon { font-size:15px; width:18px; text-align:center; }
  .sidebar-footer {
    margin-top:auto; padding: 16px 20px;
    border-top:1px solid var(--border);
  }
  .status-badge {
    display:flex; align-items:center; gap:8px;
    font-size:11px; color:var(--emerald);
    background:var(--emerald-dim); border:1px solid rgba(16,232,126,0.2);
    padding:6px 10px; border-radius:6px;
  }
  .status-dot { width:6px; height:6px; background:var(--emerald); border-radius:50%; animation:pulse 2s infinite; }

  /* ─── MAIN ─── */
  .main { margin-left:220px; flex:1; padding:32px 36px; max-width:1400px; }

  /* ─── HEADER ─── */
  .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:32px; }
  .page-title { font-size:24px; font-weight:800; letter-spacing:-0.5px; }
  .page-sub { font-size:13px; color:var(--muted); margin-top:3px; font-family:'JetBrains Mono',monospace; }
  .header-right { display:flex; align-items:center; gap:12px; }
  .live-badge {
    display:flex; align-items:center; gap:6px;
    background:var(--emerald-dim); border:1px solid rgba(16,232,126,0.2);
    padding:6px 12px; border-radius:100px;
    font-size:11px; font-family:'JetBrains Mono',monospace; color:var(--emerald);
  }
  .live-dot { width:6px; height:6px; background:var(--emerald); border-radius:50%; animation:blink 1.5s infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
  .date-badge {
    font-size:12px; color:var(--muted); font-family:'JetBrains Mono',monospace;
    background:var(--panel); border:1px solid var(--border);
    padding:6px 12px; border-radius:8px;
  }

  /* ─── KPI ROW ─── */
  .kpi-row { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px; }
  .kpi-card {
    background:var(--panel); border:1px solid var(--border);
    border-radius:12px; padding:20px;
    position:relative; overflow:hidden;
    transition: border-color 0.2s;
  }
  .kpi-card:hover { border-color:var(--border-bright); }
  .kpi-card.green { border-color:rgba(16,232,126,0.2); }
  .kpi-card.purple { border-color:rgba(124,106,247,0.2); }
  .kpi-card.amber { border-color:rgba(245,166,35,0.2); }
  .kpi-card.blue { border-color:rgba(59,130,246,0.2); }
  .kpi-label { font-size:11px; color:var(--muted); font-family:'JetBrains Mono',monospace; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px; }
  .kpi-value { font-size:32px; font-weight:800; letter-spacing:-1px; line-height:1; }
  .kpi-value.green { color:var(--emerald); }
  .kpi-value.purple { color:var(--signal); }
  .kpi-value.amber { color:var(--amber); }
  .kpi-value.blue { color:var(--blue); }
  .kpi-meta { font-size:12px; color:var(--muted); margin-top:8px; display:flex; align-items:center; gap:6px; }
  .kpi-change { font-size:11px; font-family:'JetBrains Mono',monospace; padding:2px 6px; border-radius:4px; }
  .kpi-change.up { background:var(--emerald-dim); color:var(--emerald); }
  .kpi-change.down { background:var(--red-dim); color:var(--red); }
  .kpi-glow {
    position:absolute; width:80px; height:80px; border-radius:50%;
    top:-20px; right:-20px; opacity:0.15;
  }
  .kpi-glow.green { background:var(--emerald); }
  .kpi-glow.purple { background:var(--signal); }
  .kpi-glow.amber { background:var(--amber); }
  .kpi-glow.blue { background:var(--blue); }

  /* ─── GRID ─── */
  .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px; }
  .grid-3 { display:grid; grid-template-columns:2fr 1fr; gap:20px; margin-bottom:20px; }

  /* ─── PANEL ─── */
  .panel {
    background:var(--panel); border:1px solid var(--border);
    border-radius:12px; overflow:hidden;
  }
  .panel-header {
    padding:16px 20px; border-bottom:1px solid var(--border);
    display:flex; align-items:center; justify-content:space-between;
  }
  .panel-title { font-size:14px; font-weight:700; }
  .panel-tag {
    font-size:10px; font-family:'JetBrains Mono',monospace; color:var(--muted);
    background:var(--surface); border:1px solid var(--border);
    padding:3px 8px; border-radius:4px;
  }
  .panel-body { padding:20px; }

  /* ─── SERVER STATUS ─── */
  .server-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:16px; }
  .server-card {
    background:var(--panel); border:1px solid var(--border);
    border-radius:12px; padding:16px;
    transition: all 0.2s;
  }
  .server-card:hover { border-color:var(--border-bright); }
  .server-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
  .server-name { font-size:14px; font-weight:600; }
  .server-status {
    font-size:10px; font-family:'JetBrains Mono',monospace;
    padding:3px 8px; border-radius:4px; text-transform:uppercase;
  }
  .server-status.online { background:var(--emerald-dim); color:var(--emerald); }
  .server-status.warning { background:var(--amber-dim); color:var(--amber); }
  .server-status.offline { background:var(--red-dim); color:var(--red); }
  .server-metrics { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; font-size:11px; }
  .metric { text-align:center; }
  .metric-value { font-weight:600; color:var(--white); }
  .metric-label { color:var(--muted); margin-top:2px; }

  /* ─── ACTIVITY LOG ─── */
  .activity-item {
    display:flex; align-items:center; gap:12px;
    padding:12px 0; border-bottom:1px solid var(--border);
  }
  .activity-item:last-child { border-bottom:none; }
  .activity-icon {
    width:32px; height:32px; border-radius:8px;
    display:grid; place-items:center; font-size:14px;
    flex-shrink:0;
  }
  .activity-icon.success { background:var(--emerald-dim); color:var(--emerald); }
  .activity-icon.warning { background:var(--amber-dim); color:var(--amber); }
  .activity-icon.error { background:var(--red-dim); color:var(--red); }
  .activity-icon.info { background:var(--blue-dim); color:var(--blue); }
  .activity-content { flex:1; min-width:0; }
  .activity-title { font-size:13px; font-weight:600; margin-bottom:2px; }
  .activity-desc { font-size:12px; color:var(--muted); }
  .activity-time {
    font-size:11px; color:var(--muted); font-family:'JetBrains Mono',monospace;
    flex-shrink:0;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .sidebar { transform: translateX(-100%); }
    .main { margin-left: 0; padding: 20px 16px; }
    .kpi-row { grid-template-columns: 1fr 1fr; }
    .server-grid { grid-template-columns: 1fr; }
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .kpi-row { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-mark">🎯</div>
    <div>
      <div class="logo-text">MrDelegate</div>
      <div class="logo-sub">operations</div>
    </div>
  </div>

  <div class="nav-section">
    <div class="nav-label">Operations</div>
    <a href="/ops" class="nav-item active">
      <span class="nav-icon">📊</span>
      <span>Dashboard</span>
    </a>
    <a href="/ops/dashboard" class="nav-item">
      <span class="nav-icon">📈</span>
      <span>Live Data</span>
    </a>
    <a href="/admindashboard" class="nav-item">
      <span class="nav-icon">⚙️</span>
      <span>Admin Panel</span>
    </a>
  </div>

  <div class="nav-section">
    <div class="nav-label">Monitoring</div>
    <a href="#" class="nav-item">
      <span class="nav-icon">🖥️</span>
      <span>Servers</span>
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">🚨</span>
      <span>Alerts</span>
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">📋</span>
      <span>Logs</span>
    </a>
  </div>

  <div class="sidebar-footer">
    <div class="status-badge">
      <span class="status-dot"></span>
      <span>All systems operational</span>
    </div>
  </div>
</div>

<div class="main">
  <div class="page-header">
    <div>
      <h1 class="page-title">Operations Dashboard</h1>
      <p class="page-sub">Real-time system monitoring and operations control</p>
    </div>
    <div class="header-right">
      <div class="live-badge">
        <span class="live-dot"></span>
        <span>LIVE</span>
      </div>
      <div class="date-badge" id="currentDate"></div>
    </div>
  </div>

  <!-- KPI Row -->
  <div class="kpi-row">
    <div class="kpi-card green">
      <div class="kpi-glow green"></div>
      <div class="kpi-label">Active Servers</div>
      <div class="kpi-value green" id="activeServers">8</div>
      <div class="kpi-meta">
        <span class="kpi-change up">+2</span>
        <span>vs last week</span>
      </div>
    </div>
    <div class="kpi-card blue">
      <div class="kpi-glow blue"></div>
      <div class="kpi-label">System Uptime</div>
      <div class="kpi-value blue">99.8%</div>
      <div class="kpi-meta">
        <span class="kpi-change up">+0.1%</span>
        <span>this month</span>
      </div>
    </div>
    <div class="kpi-card purple">
      <div class="kpi-glow purple"></div>
      <div class="kpi-label">Active Users</div>
      <div class="kpi-value purple" id="activeUsers">1,247</div>
      <div class="kpi-meta">
        <span class="kpi-change up">+8.3%</span>
        <span>vs yesterday</span>
      </div>
    </div>
    <div class="kpi-card amber">
      <div class="kpi-glow amber"></div>
      <div class="kpi-label">Response Time</div>
      <div class="kpi-value amber">142ms</div>
      <div class="kpi-meta">
        <span class="kpi-change down">+12ms</span>
        <span>avg response</span>
      </div>
    </div>
  </div>

  <!-- Main Grid -->
  <div class="grid-3">
    <!-- Server Status -->
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">Server Status</div>
        <div class="panel-tag">8 servers</div>
      </div>
      <div class="panel-body">
        <div class="server-grid">
          <div class="server-card">
            <div class="server-header">
              <div class="server-name">Web-01</div>
              <div class="server-status online">online</div>
            </div>
            <div class="server-metrics">
              <div class="metric">
                <div class="metric-value">23%</div>
                <div class="metric-label">CPU</div>
              </div>
              <div class="metric">
                <div class="metric-value">67%</div>
                <div class="metric-label">Memory</div>
              </div>
              <div class="metric">
                <div class="metric-value">45%</div>
                <div class="metric-label">Disk</div>
              </div>
            </div>
          </div>
          <div class="server-card">
            <div class="server-header">
              <div class="server-name">DB-01</div>
              <div class="server-status online">online</div>
            </div>
            <div class="server-metrics">
              <div class="metric">
                <div class="metric-value">56%</div>
                <div class="metric-label">CPU</div>
              </div>
              <div class="metric">
                <div class="metric-value">78%</div>
                <div class="metric-label">Memory</div>
              </div>
              <div class="metric">
                <div class="metric-value">34%</div>
                <div class="metric-label">Disk</div>
              </div>
            </div>
          </div>
          <div class="server-card">
            <div class="server-header">
              <div class="server-name">Cache-01</div>
              <div class="server-status warning">warning</div>
            </div>
            <div class="server-metrics">
              <div class="metric">
                <div class="metric-value">89%</div>
                <div class="metric-label">CPU</div>
              </div>
              <div class="metric">
                <div class="metric-value">91%</div>
                <div class="metric-label">Memory</div>
              </div>
              <div class="metric">
                <div class="metric-value">67%</div>
                <div class="metric-label">Disk</div>
              </div>
            </div>
          </div>
          <div class="server-card">
            <div class="server-header">
              <div class="server-name">API-01</div>
              <div class="server-status online">online</div>
            </div>
            <div class="server-metrics">
              <div class="metric">
                <div class="metric-value">34%</div>
                <div class="metric-label">CPU</div>
              </div>
              <div class="metric">
                <div class="metric-value">52%</div>
                <div class="metric-label">Memory</div>
              </div>
              <div class="metric">
                <div class="metric-value">29%</div>
                <div class="metric-label">Disk</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Activity Log -->
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">Recent Activity</div>
        <div class="panel-tag">live</div>
      </div>
      <div class="panel-body">
        <div class="activity-item">
          <div class="activity-icon success">✅</div>
          <div class="activity-content">
            <div class="activity-title">Deploy completed</div>
            <div class="activity-desc">v2.1.4 successfully deployed to production</div>
          </div>
          <div class="activity-time">2m ago</div>
        </div>
        <div class="activity-item">
          <div class="activity-icon warning">⚠️</div>
          <div class="activity-content">
            <div class="activity-title">High memory usage</div>
            <div class="activity-desc">Cache-01 memory usage exceeded 90%</div>
          </div>
          <div class="activity-time">5m ago</div>
        </div>
        <div class="activity-item">
          <div class="activity-icon info">ℹ️</div>
          <div class="activity-content">
            <div class="activity-title">Backup completed</div>
            <div class="activity-desc">Daily database backup finished successfully</div>
          </div>
          <div class="activity-time">1h ago</div>
        </div>
        <div class="activity-item">
          <div class="activity-icon success">✅</div>
          <div class="activity-content">
            <div class="activity-title">SSL certificate renewed</div>
            <div class="activity-desc">Certificate for *.mrdelegate.ai renewed</div>
          </div>
          <div class="activity-time">3h ago</div>
        </div>
        <div class="activity-item">
          <div class="activity-icon error">❌</div>
          <div class="activity-content">
            <div class="activity-title">Connection timeout</div>
            <div class="activity-desc">External API timeout resolved automatically</div>
          </div>
          <div class="activity-time">6h ago</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Update current date
function updateDate() {
  const now = new Date();
  const dateStr = now.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
  document.getElementById('currentDate').textContent = dateStr;
}

// Simulate real-time data updates
function updateMetrics() {
  const activeServers = document.getElementById('activeServers');
  const activeUsers = document.getElementById('activeUsers');

  // Slight variations to simulate real-time data
  if (Math.random() > 0.8) {
    const servers = parseInt(activeServers.textContent);
    activeServers.textContent = Math.max(6, servers + (Math.random() > 0.5 ? 1 : -1));
  }

  if (Math.random() > 0.7) {
    const users = parseInt(activeUsers.textContent.replace(',', ''));
    const variation = Math.floor((Math.random() - 0.5) * 20);
    activeUsers.textContent = (users + variation).toLocaleString();
  }
}

// Initialize
updateDate();
setInterval(updateDate, 60000); // Update every minute
setInterval(updateMetrics, 5000); // Update metrics every 5 seconds
</script>

</body>
</html>