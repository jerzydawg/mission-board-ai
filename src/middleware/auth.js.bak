import jwt from 'jsonwebtoken';
import bcrypt from 'bcryptjs';

const JWT_SECRET = (() => { if (!process.env.JWT_SECRET) throw new Error('JWT_SECRET env var required'); return process.env.JWT_SECRET; })();
const ADMIN_EMAIL = (() => { if (!process.env.ADMIN_EMAIL) throw new Error('ADMIN_EMAIL env var required'); return process.env.ADMIN_EMAIL; })();
const ADMIN_PASSWORD_HASH = (() => {
  if (!process.env.ADMIN_PASSWORD_HASH) throw new Error('ADMIN_PASSWORD_HASH env var required');
  return process.env.ADMIN_PASSWORD_HASH;
})();
const SESSION_HOURS = 24;

// Simple in-memory rate limiter for login
const loginAttempts = new Map();
const MAX_ATTEMPTS = 5;
const WINDOW_MS = 15 * 60 * 1000; // 15 minutes

function checkRateLimit(ip) {
  const now = Date.now();
  const entry = loginAttempts.get(ip);
  if (!entry || now - entry.start > WINDOW_MS) {
    loginAttempts.set(ip, { count: 1, start: now });
    return true;
  }
  entry.count++;
  if (entry.count > MAX_ATTEMPTS) return false;
  return true;
}

// Single admin user — founder only
const ADMIN = {
  email: ADMIN_EMAIL,
  passwordHash: ADMIN_PASSWORD_HASH,
};

export function verifyAdmin(c, next) {
  const token = c.req.header('Authorization')?.replace('Bearer ', '') ||
    getCookie(c, 'md_admin_token');

  if (!token) return c.json({ error: 'Not authenticated' }, 401);

  try {
    const decoded = jwt.verify(token, JWT_SECRET);
    if (decoded.email !== ADMIN.email) return c.json({ error: 'Unauthorized' }, 403);
    c.set('admin', decoded);
    return next();
  } catch {
    return c.json({ error: 'Invalid or expired token' }, 401);
  }
}

export function loginAdmin(email, password, ip) {
  if (ip && !checkRateLimit(ip)) return { error: 'rate_limited' };
  if (email !== ADMIN.email) return null;
  if (!bcrypt.compareSync(password, ADMIN.passwordHash)) { console.log('[auth] Login failed for', email, '- password mismatch'); return null; }

  const token = jwt.sign(
    { email, role: 'admin' },
    JWT_SECRET,
    { expiresIn: `${SESSION_HOURS}h` }
  );
  return token;
}

function getCookie(c, name) {
  const cookies = c.req.header('Cookie') || '';
  const match = cookies.match(new RegExp(`${name}=([^;]+)`));
  return match ? match[1] : null;
}

// Debug helper - log auth attempts (remove in prod if too noisy)
export function debugAuth(email, success, reason = '') {
  console.log(`[auth-debug] ${email} | ${success ? '✓' : '✗'} | ${reason || 'ok'}`);
}
