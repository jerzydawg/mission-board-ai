<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Operations — MrDelegate</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    /* Core palette */
    --void: #04050a;
    --bg: #08090f;
    --surface: #0c0d14;
    --surface-elevated: #10111a;
    --card: #12141e;
    
    /* Borders */
    --border-dim: rgba(255,255,255,0.04);
    --border: rgba(255,255,255,0.08);
    --border-bright: rgba(255,255,255,0.12);
    
    /* Text */
    --text-primary: #f4f4f7;
    --text-secondary: #9ca3b4;
    --text-muted: #5c6478;
    
    /* Brand */
    --brand: #ff6b35;
    --brand-secondary: #f7931a;
    --brand-glow: rgba(255,107,53,0.12);
    --brand-glow-strong: rgba(255,107,53,0.25);
    
    /* Semantic */
    --success: #22c55e;
    --success-dim: rgba(34,197,94,0.1);
    --warning: #f59e0b;
    --warning-dim: rgba(245,158,11,0.1);
    --error: #ef4444;
    --error-dim: rgba(239,68,68,0.1);
    --info: #3b82f6;
    --info-dim: rgba(59,130,246,0.1);
    
    /* Spacing */
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 14px;
    --radius-xl: 20px;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
    background: var(--void);
    color: var(--text-secondary);
    min-height: 100vh;
    display: flex;
    -webkit-font-smoothing: antialiased;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: 
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(255,107,53,0.04), transparent 70%),
      linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 100% 100%, 48px 48px, 48px 48px;
    pointer-events: none;
  }

  /* ─── SIDEBAR ─── */
  .sidebar {
    width: 240px;
    min-height: 100vh;
    background: var(--bg);
    border-right: 1px solid var(--border-dim);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 100;
  }

  .sidebar-header {
    padding: 24px 20px;
    border-bottom: 1px solid var(--border-dim);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-mark {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }

  .logo-info {
    display: flex;
    flex-direction: column;
  }

  .logo-name {
    font-size: 16px;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .logo-name .brand { color: var(--brand); }

  .logo-tag {
    font-size: 10px;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 2px;
  }

  .sidebar-nav {
    flex: 1;
    padding: 16px 12px;
    overflow-y: auto;
  }

  .nav-section {
    margin-bottom: 24px;
  }

  .nav-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0 8px 10px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.15s ease;
    margin-bottom: 2px;
  }

  .nav-item:hover {
    background: rgba(255,255,255,0.04);
    color: var(--text-primary);
  }

  .nav-item.active {
    background: var(--brand-glow);
    color: var(--brand);
    font-weight: 600;
  }

  .nav-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    width: 3px;
    height: 24px;
    background: var(--brand);
    border-radius: 0 2px 2px 0;
  }

  .nav-icon {
    font-size: 16px;
    width: 20px;
    text-align: center;
    flex-shrink: 0;
  }

  .nav-badge {
    margin-left: auto;
    background: var(--error);
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 10px;
    font-family: 'JetBrains Mono', monospace;
  }

  .sidebar-footer {
    padding: 16px;
    border-top: 1px solid var(--border-dim);
  }

  .status-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px;
    background: var(--success-dim);
    border: 1px solid rgba(34,197,94,0.15);
    border-radius: var(--radius-md);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: var(--success);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.9); }
  }

  .status-text {
    font-size: 12px;
    font-weight: 600;
    color: var(--success);
  }

  /* ─── MAIN ─── */
  .main {
    margin-left: 240px;
    flex: 1;
    padding: 32px 40px;
    max-width: 1600px;
    min-height: 100vh;
  }

  /* ─── HEADER ─── */
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }

  .page-title-group h1 {
    font-size: 26px;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .page-title-group p {
    font-size: 14px;
    color: var(--text-muted);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .live-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--success-dim);
    border: 1px solid rgba(34,197,94,0.2);
    padding: 8px 16px;
    border-radius: 100px;
  }

  .live-dot {
    width: 6px;
    height: 6px;
    background: var(--success);
    border-radius: 50%;
    animation: blink 1.5s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .live-text {
    font-size: 11px;
    font-weight: 700;
    color: var(--success);
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.05em;
  }

  .date-display {
    font-size: 12px;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 8px 14px;
    border-radius: var(--radius-md);
  }

  /* ─── KPI GRID ─── */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 28px;
  }

  .kpi-card {
    background: var(--card);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-lg);
    padding: 24px;
    position: relative;
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .kpi-card:hover {
    border-color: var(--border);
    transform: translateY(-2px);
  }

  .kpi-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    opacity: 0.6;
  }

  .kpi-card.green::before { background: var(--success); }
  .kpi-card.blue::before { background: var(--info); }
  .kpi-card.brand::before { background: var(--brand); }
  .kpi-card.amber::before { background: var(--warning); }

  .kpi-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
    font-family: 'JetBrains Mono', monospace;
  }

  .kpi-value {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 12px;
  }

  .kpi-value.green { color: var(--success); }
  .kpi-value.blue { color: var(--info); }
  .kpi-value.brand { color: var(--brand); }
  .kpi-value.amber { color: var(--warning); }

  .kpi-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text-muted);
  }

  .kpi-change {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
  }

  .kpi-change.up {
    background: var(--success-dim);
    color: var(--success);
  }

  .kpi-change.down {
    background: var(--error-dim);
    color: var(--error);
  }

  /* ─── GRID LAYOUTS ─── */
  .grid-2-1 {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  /* ─── PANELS ─── */
  .panel {
    background: var(--card);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    border-bottom: 1px solid var(--border-dim);
  }

  .panel-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
  }

  .panel-badge {
    font-size: 10px;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    font-family: 'JetBrains Mono', monospace;
  }

  .panel-body {
    padding: 20px 24px;
  }

  /* ─── SERVER CARDS ─── */
  .server-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .server-card {
    background: var(--surface);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    padding: 16px;
    transition: all 0.2s ease;
  }

  .server-card:hover {
    border-color: var(--border);
  }

  .server-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .server-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
  }

  .server-status {
    font-size: 10px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: 'JetBrains Mono', monospace;
  }

  .server-status.online {
    background: var(--success-dim);
    color: var(--success);
  }

  .server-status.warning {
    background: var(--warning-dim);
    color: var(--warning);
  }

  .server-status.offline {
    background: var(--error-dim);
    color: var(--error);
  }

  .server-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .metric {
    text-align: center;
    padding: 8px 0;
    background: var(--bg);
    border-radius: var(--radius-sm);
  }

  .metric-value {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
    font-family: 'JetBrains Mono', monospace;
  }

  .metric-label {
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 2px;
  }

  /* ─── ACTIVITY LOG ─── */
  .activity-list {
    display: flex;
    flex-direction: column;
  }

  .activity-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border-dim);
  }

  .activity-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .activity-item:first-child {
    padding-top: 0;
  }

  .activity-icon {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }

  .activity-icon.success {
    background: var(--success-dim);
  }

  .activity-icon.warning {
    background: var(--warning-dim);
  }

  .activity-icon.error {
    background: var(--error-dim);
  }

  .activity-icon.info {
    background: var(--info-dim);
  }

  .activity-content {
    flex: 1;
    min-width: 0;
  }

  .activity-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 3px;
  }

  .activity-desc {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .activity-time {
    font-size: 11px;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1200px) {
    .kpi-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .grid-2-1 {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .sidebar {
      transform: translateX(-100%);
      transition: transform 0.3s ease;
    }

    .sidebar.open {
      transform: translateX(0);
    }

    .main {
      margin-left: 0;
      padding: 20px 16px;
    }

    .kpi-grid {
      grid-template-columns: 1fr;
    }

    .server-grid {
      grid-template-columns: 1fr;
    }

    .page-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }
</style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-header">
    <div class="logo">
      <div class="logo-mark">
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="brandGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#FF6B35"/>
              <stop offset="100%" style="stop-color:#F7931A"/>
            </linearGradient>
          </defs>
          <g transform="translate(2, 2)">
            <path d="M22 2 L40 12 L40 32 L22 42 L4 32 L4 12 Z" fill="none" stroke="url(#brandGrad)" stroke-width="2.5" stroke-linejoin="round"/>
            <path d="M22 10 L32 22 L22 34 L12 22 Z" fill="url(#brandGrad)" opacity="0.9"/>
            <circle cx="22" cy="22" r="4" fill="#08090f"/>
            <circle cx="22" cy="2" r="3" fill="url(#brandGrad)"/>
            <circle cx="40" cy="12" r="3" fill="url(#brandGrad)"/>
            <circle cx="40" cy="32" r="3" fill="url(#brandGrad)"/>
            <circle cx="22" cy="42" r="3" fill="url(#brandGrad)"/>
            <circle cx="4" cy="32" r="3" fill="url(#brandGrad)"/>
            <circle cx="4" cy="12" r="3" fill="url(#brandGrad)"/>
          </g>
        </svg>
      </div>
      <div class="logo-info">
        <div class="logo-name"><span class="brand">Mr</span>Delegate</div>
        <div class="logo-tag">Operations</div>
      </div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section">
      <div class="nav-label">Overview</div>
      <a href="/ops" class="nav-item active">
        <span class="nav-icon">📊</span>
        <span>Dashboard</span>
      </a>
      <a href="/ops/dashboard" class="nav-item">
        <span class="nav-icon">📈</span>
        <span>Live Analytics</span>
      </a>
      <a href="/admindashboard" class="nav-item">
        <span class="nav-icon">⚙️</span>
        <span>Admin Panel</span>
      </a>
    </div>

    <div class="nav-section">
      <div class="nav-label">Infrastructure</div>
      <a href="#" class="nav-item">
        <span class="nav-icon">🖥️</span>
        <span>Servers</span>
      </a>
      <a href="#" class="nav-item">
        <span class="nav-icon">🌐</span>
        <span>Domains</span>
      </a>
      <a href="#" class="nav-item">
        <span class="nav-icon">🔐</span>
        <span>SSL Certs</span>
      </a>
    </div>

    <div class="nav-section">
      <div class="nav-label">Monitoring</div>
      <a href="#" class="nav-item">
        <span class="nav-icon">🚨</span>
        <span>Alerts</span>
        <span class="nav-badge">3</span>
      </a>
      <a href="#" class="nav-item">
        <span class="nav-icon">📋</span>
        <span>Logs</span>
      </a>
      <a href="#" class="nav-item">
        <span class="nav-icon">🔧</span>
        <span>Deployments</span>
      </a>
    </div>
  </nav>

  <div class="sidebar-footer">
    <div class="status-card">
      <span class="status-dot"></span>
      <span class="status-text">All Systems Operational</span>
    </div>
  </div>
</aside>

<main class="main">
  <header class="page-header">
    <div class="page-title-group">
      <h1>Operations Dashboard</h1>
      <p>Real-time system monitoring and control center</p>
    </div>
    <div class="header-actions">
      <div class="live-indicator">
        <span class="live-dot"></span>
        <span class="live-text">LIVE</span>
      </div>
      <div class="date-display" id="currentDate"></div>
    </div>
  </header>

  <!-- KPI Grid -->
  <section class="kpi-grid">
    <div class="kpi-card green">
      <div class="kpi-label">Active Servers</div>
      <div class="kpi-value green" id="activeServers">8</div>
      <div class="kpi-meta">
        <span class="kpi-change up">↑ +2</span>
        <span>vs last week</span>
      </div>
    </div>
    <div class="kpi-card blue">
      <div class="kpi-label">System Uptime</div>
      <div class="kpi-value blue">99.8%</div>
      <div class="kpi-meta">
        <span class="kpi-change up">↑ +0.1%</span>
        <span>this month</span>
      </div>
    </div>
    <div class="kpi-card brand">
      <div class="kpi-label">Active Users</div>
      <div class="kpi-value brand" id="activeUsers">1,247</div>
      <div class="kpi-meta">
        <span class="kpi-change up">↑ +8.3%</span>
        <span>vs yesterday</span>
      </div>
    </div>
    <div class="kpi-card amber">
      <div class="kpi-label">Avg Response</div>
      <div class="kpi-value amber">142ms</div>
      <div class="kpi-meta">
        <span class="kpi-change down">↓ +12ms</span>
        <span>response time</span>
      </div>
    </div>
  </section>

  <!-- Main Grid -->
  <section class="grid-2-1">
    <!-- Server Status Panel -->
    <div class="panel">
      <div class="panel-header">
        <h2 class="panel-title">Server Status</h2>
        <span class="panel-badge">8 servers</span>
      </div>
      <div class="panel-body">
        <div class="server-grid">
          <div class="server-card">
            <div class="server-header">
              <div class="server-name">Web-01</div>
              <div class="server-status online">Online</div>
            </div>
            <div class="server-metrics">
              <div class="metric">
                <div class="metric-value">23%</div>
                <div class="metric-label">CPU</div>
              </div>
              <div class="metric">
                <div class="metric-value">67%</div>
                <div class="metric-label">RAM</div>
              </div>
              <div class="metric">
                <div class="metric-value">45%</div>
                <div class="metric-label">Disk</div>
              </div>
            </div>
          </div>
          <div class="server-card">
            <div class="server-header">
              <div class="server-name">DB-01</div>
              <div class="server-status online">Online</div>
            </div>
            <div class="server-metrics">
              <div class="metric">
                <div class="metric-value">56%</div>
                <div class="metric-label">CPU</div>
              </div>
              <div class="metric">
                <div class="metric-value">78%</div>
                <div class="metric-label">RAM</div>
              </div>
              <div class="metric">
                <div class="metric-value">34%</div>
                <div class="metric-label">Disk</div>
              </div>
            </div>
          </div>
          <div class="server-card">
            <div class="server-header">
              <div class="server-name">Cache-01</div>
              <div class="server-status warning">Warning</div>
            </div>
            <div class="server-metrics">
              <div class="metric">
                <div class="metric-value">89%</div>
                <div class="metric-label">CPU</div>
              </div>
              <div class="metric">
                <div class="metric-value">91%</div>
                <div class="metric-label">RAM</div>
              </div>
              <div class="metric">
                <div class="metric-value">67%</div>
                <div class="metric-label">Disk</div>
              </div>
            </div>
          </div>
          <div class="server-card">
            <div class="server-header">
              <div class="server-name">API-01</div>
              <div class="server-status online">Online</div>
            </div>
            <div class="server-metrics">
              <div class="metric">
                <div class="metric-value">34%</div>
                <div class="metric-label">CPU</div>
              </div>
              <div class="metric">
                <div class="metric-value">52%</div>
                <div class="metric-label">RAM</div>
              </div>
              <div class="metric">
                <div class="metric-value">29%</div>
                <div class="metric-label">Disk</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Activity Log -->
    <div class="panel">
      <div class="panel-header">
        <h2 class="panel-title">Recent Activity</h2>
        <span class="panel-badge">live</span>
      </div>
      <div class="panel-body">
        <div class="activity-list">
          <div class="activity-item">
            <div class="activity-icon success">✓</div>
            <div class="activity-content">
              <div class="activity-title">Deploy completed</div>
              <div class="activity-desc">v2.1.4 deployed to production</div>
            </div>
            <div class="activity-time">2m ago</div>
          </div>
          <div class="activity-item">
            <div class="activity-icon warning">⚠</div>
            <div class="activity-content">
              <div class="activity-title">High memory usage</div>
              <div class="activity-desc">Cache-01 exceeded 90% threshold</div>
            </div>
            <div class="activity-time">5m ago</div>
          </div>
          <div class="activity-item">
            <div class="activity-icon info">ℹ</div>
            <div class="activity-content">
              <div class="activity-title">Backup completed</div>
              <div class="activity-desc">Daily database backup successful</div>
            </div>
            <div class="activity-time">1h ago</div>
          </div>
          <div class="activity-item">
            <div class="activity-icon success">✓</div>
            <div class="activity-content">
              <div class="activity-title">SSL renewed</div>
              <div class="activity-desc">*.mrdelegate.ai certificate renewed</div>
            </div>
            <div class="activity-time">3h ago</div>
          </div>
          <div class="activity-item">
            <div class="activity-icon error">✕</div>
            <div class="activity-content">
              <div class="activity-title">Connection timeout</div>
              <div class="activity-desc">API timeout resolved automatically</div>
            </div>
            <div class="activity-time">6h ago</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
function updateDate() {
  const now = new Date();
  const options = { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' };
  document.getElementById('currentDate').textContent = now.toLocaleDateString('en-US', options);
}

function updateMetrics() {
  const activeServers = document.getElementById('activeServers');
  const activeUsers = document.getElementById('activeUsers');

  if (Math.random() > 0.85) {
    const servers = parseInt(activeServers.textContent);
    activeServers.textContent = Math.max(6, servers + (Math.random() > 0.5 ? 1 : -1));
  }

  if (Math.random() > 0.75) {
    const users = parseInt(activeUsers.textContent.replace(',', ''));
    const variation = Math.floor((Math.random() - 0.5) * 20);
    activeUsers.textContent = (users + variation).toLocaleString();
  }
}

updateDate();
setInterval(updateDate, 60000);
setInterval(updateMetrics, 5000);
</script>

</body>
</html>
